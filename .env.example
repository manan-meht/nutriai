# ============================================================
# Tistra Health — Environment Variables (example only)
# Copy to .env.local and fill in real values. Never commit .env.local.
# ============================================================

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- AI providers ----
GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# ---- Product routing ----
NEXT_PUBLIC_PRODUCT=gym
NEXT_PUBLIC_GYM_DOMAIN=coach.tistrahealth.com
NEXT_PUBLIC_FAMILY_DOMAIN=family.tistrahealth.com

# ---- Landing page experiment ----
GYM_LANDING_MODE=ab_test
ADULTS_LANDING_MODE=ab_test
LANDING_IMMERSIVE_SPLIT_PCT=50
ALLOW_LANDING_OVERRIDE=false

# ---- WhatsApp ----
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# Message template for the first-ever message to a newly added family
# member (Meta requires an approved template for this — free-form text is
# rejected as the first message to someone who hasn't messaged you yet, in
# both test and production WhatsApp Business Accounts). Create this in
# Meta Business Manager > WhatsApp Manager > Message Templates, category
# UTILITY, with body text like:
#
#   Hi {{1}}! 👋
#
#   {{2}} has set up Tistra Health to help keep an eye on your nutrition.
#
#   All you need to do is send me a photo or describe what you eat — right
#   here on WhatsApp. I'll keep track for you!
#
#   Whenever you're ready, just send me a photo of your next meal 😊
#
# {{1}} = the family member's first name, {{2}} = the caregiver's name.
# Until this is approved, invites fall back to a free-form send that Meta
# will reject for genuinely new contacts.
WHATSAPP_INVITE_TEMPLATE_NAME=
WHATSAPP_INVITE_TEMPLATE_LANGUAGE=en_US

# ---- Feature flags (unified home / limits / trials) ----
NEXT_PUBLIC_UNIFIED_HOME_ENABLED=true
# App-layer pre-check + Add-button visibility only — the DB triggers in
# 0002-0004 always enforce the 2/5 limit regardless of these flags.
NEXT_PUBLIC_FAMILY_LIMIT_ENFORCEMENT_ENABLED=true
NEXT_PUBLIC_GYM_LIMIT_ENFORCEMENT_ENABLED=true

# ---- Feature flags (billing) ----
# Master switch: when false, entitlement status is computed/displayed but
# never blocks actions (safe first deploy of read-only enforcement).
NEXT_PUBLIC_SUBSCRIPTION_ENFORCEMENT_ENABLED=true
# Per-module trial-expiry enforcement, gated behind the master switch above.
NEXT_PUBLIC_FAMILY_TRIAL_ENFORCEMENT_ENABLED=true
NEXT_PUBLIC_GYM_TRIAL_ENFORCEMENT_ENABLED=true
NEXT_PUBLIC_STRIPE_CHECKOUT_ENABLED=true
NEXT_PUBLIC_INTL_USD_BILLING_ENABLED=true
# Razorpay stays off until India merchant + recurring-payment approval is complete.
NEXT_PUBLIC_RAZORPAY_ENABLED=false
# Singapore PayNow: one-time annual prepaid only, never recurring monthly.
NEXT_PUBLIC_PAYNOW_ENABLED=false
# US ACH bank debit — off until Stripe merchant account is confirmed eligible.
NEXT_PUBLIC_ACH_ENABLED=false
# Australia BECS Direct Debit — same caveat as ACH.
NEXT_PUBLIC_BECS_ENABLED=false
# Configurable activation date for the existing-user trial/limit migration story.
FEATURE_ACTIVATION_DATE=

# ---- Stripe (test mode) ----
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs — one per (market, module, interval). Create these in the
# Stripe Dashboard (test mode) and paste the price IDs here.
STRIPE_PRICE_US_ADULTS_MONTHLY=
STRIPE_PRICE_US_ADULTS_ANNUAL=
STRIPE_PRICE_US_GYM_MONTHLY=
STRIPE_PRICE_US_GYM_ANNUAL=
STRIPE_PRICE_SG_ADULTS_MONTHLY=
STRIPE_PRICE_SG_ADULTS_ANNUAL=
STRIPE_PRICE_SG_GYM_MONTHLY=
STRIPE_PRICE_SG_GYM_ANNUAL=
STRIPE_PRICE_AU_ADULTS_MONTHLY=
STRIPE_PRICE_AU_ADULTS_ANNUAL=
STRIPE_PRICE_AU_GYM_MONTHLY=
STRIPE_PRICE_AU_GYM_ANNUAL=
STRIPE_PRICE_INTL_ADULTS_MONTHLY=
STRIPE_PRICE_INTL_ADULTS_ANNUAL=
STRIPE_PRICE_INTL_GYM_MONTHLY=
STRIPE_PRICE_INTL_GYM_ANNUAL=
# Note: IN market uses Razorpay, not Stripe — no STRIPE_PRICE_IN_* needed.

# ---- Razorpay (test mode, India only) ----
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_ADULTS_MONTHLY=
RAZORPAY_PLAN_ADULTS_ANNUAL=
RAZORPAY_PLAN_GYM_MONTHLY=
RAZORPAY_PLAN_GYM_ANNUAL=
